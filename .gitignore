# =============================================================================
# METAL-CALC — ignoruj wszystko do końca budowania projektu
# =============================================================================

# ---------------------------------------------------------------------------
# Python — bytecode i cache
# ---------------------------------------------------------------------------
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python

# ---------------------------------------------------------------------------
# Dystrybucja i build
# ---------------------------------------------------------------------------
*.egg-info/
*.egg
.eggs/
dist/
build/
wheels/
MANIFEST

