# ---------------------------------------------------------------------------
.pytest_cache/
.coverage
.coverage.*
htmlcov/
coverage.xml
*.cover
nosetests.xml
test-results/

# ---------------------------------------------------------------------------
# Środowiska wirtualne
# ---------------------------------------------------------------------------
.venv/
venv/
env/
ENV/
.env
.env.*

# ---------------------------------------------------------------------------
# Bazy danych (pliki robocze — nie commitujemy danych produkcyjnych)
# ---------------------------------------------------------------------------
*.db
*.sqlite
*.sqlite3

# ---------------------------------------------------------------------------
# Cennik i inne dokumenty źródłowe (wrażliwe dane firmy)
# ---------------------------------------------------------------------------
*.xlsx
*.xls
*.ods
*.csv

# ---------------------------------------------------------------------------
# Logi i pliki tymczasowe
# ---------------------------------------------------------------------------
*.log
*.tmp
*.bak
*.swp
*.swo
*~

