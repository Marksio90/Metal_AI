APP_NAME=Metal_AI
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=3000

BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000

# SECURITY: Set to explicit origins in production, e.g.:
# BACKEND_CORS_ALLOW_ORIGINS=https://app.yourcompany.com
# WARNING: '*' allows any browser origin — must NOT be used in production.
BACKEND_CORS_ALLOW_ORIGINS=*

BACKEND_REQUEST_TIMEOUT_SECONDS=20

NEXT_PUBLIC_API_BASE_URL=http://localhost:8000

LLM_PROVIDER=openai
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_TIMEOUT_SECONDS=20

# Database URL.
# Default (docker compose): PostgreSQL via the postgres service.
# For local dev without Docker, override to SQLite:
#   DATABASE_URL=sqlite:///./metal_ai.db
DATABASE_URL=postgresql+psycopg://metal:metal@postgres:5432/metal_ai

# Path to private company rates JSON.
# Leave unset to use config/company_rates.example.json as fallback.
# METAL_AI_COMPANY_RATES_PATH=config/private/company_rates.json
